{
  "name": "@d3strukt0r/portfolio",
  "version": "1.1.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "react-router build",
    "build:cf": "CLOUDFLARE=true nr build",
    "dev": "react-router dev",
    "dev:cf": "CLOUDFLARE=true nr dev",
    "deploy:cf": "nr build:cf && wrangler deploy",
    "cf-typegen": "wrangler types",
    "start": "react-router-serve ./build/client",
    "start:server": "react-router-serve ./build/server/index.js",
    "preview": "vite preview --outDir build/client",
    "typecheck": "nr cf-typegen && react-router typegen && tsc --noEmit && tsc --noEmit -p tsconfig.cloudflare.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sync:linkedin:csv": "tsx bin/linkedin/from-csv.ts",
    "sync:linkedin:api": "node --env-file=.env --import tsx bin/linkedin/from-api.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^7.17.0",
    "blurhash": "^2.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "feed": "^5.2.1",
    "gsap": "^3.15.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "isbot": "^5.1.42",
    "marked-footnote": "^1.4.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router": "^7.17.0",
    "robotstxt-util": "^4.1.0",
    "sitemap": "^9.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/ni": "^30.1.0",
    "@cloudflare/vite-plugin": "^1.40.2",
    "@iwf-web/eslint-coding-standard": "^1.1.0",
    "@iwf-web/tsconfig": "^1.1.0",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@react-router/dev": "^7.17.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/culori": "^4.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "csv-parse": "^6.2.1",
    "culori": "^4.0.2",
    "eslint": "^10.5.0",
    "gray-matter": "^4.0.3",
    "jiti": "^2.7.0",
    "jpeg-js": "^0.4.4",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "lodash": "^4.18.1",
    "marked": "^18.0.5",
    "png-to-ico": "^3.0.1",
    "sass": "^1.101.0",
    "sharp": "^0.35.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
