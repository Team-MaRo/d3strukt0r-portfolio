{
    "name": "Jekyll (Ruby)",
    "image": "mcr.microsoft.com/devcontainers/ruby:1-3.2",
    "postCreateCommand": "bundle install",
    "forwardPorts": [4000, 35729],
    "portsAttributes": {
        "4000": {
            "label": "Jekyll",
            "onAutoForward": "openBrowser"
        },
        "35729": {
            "label": "LiveReload",
            "onAutoForward": "silent"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "Shopify.ruby-lsp",
                "sissel.shopify-liquid",
                "redhat.vscode-yaml",
                "EditorConfig.EditorConfig"
            ]
        }
    }
}
