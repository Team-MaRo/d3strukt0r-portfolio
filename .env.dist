# LinkedIn Member Data Portability API access token.
# Generate via Developer Portal → Docs and tools → OAuth Token Tools with
# scope `r_dma_portability_self_serve`. Typical lifetime: 365 days.
# See docs/linkedin-data-portability.md for the full setup flow.
LINKEDIN_DMA_TOKEN=

# Comma-separated list of passphrases that can decrypt the build's sealed
# fields (employer/school names, locations, certificate URLs, profile photo).
# Each passphrase wraps the same data key separately, so rotating means
# editing this list and rebuilding. In CI this is provided via the
# REVEAL_PASSWORDS GitHub secret. Empty in dev → seal plugin uses "dev".
REVEAL_PASSWORDS=
